<odoo>

    <record id="nr_grant_portal_wizard_form_view" model="ir.ui.view">
        <field name="name">nr.grant.portal.wizard.form</field>
        <field name="model">nr.grant.portal.wizard</field>
        <field name="arch" type="xml">
            <form string="Grant Portal Access">
                <group>
                    <field name="partner_id" readonly="1"/>
                    <field name="delivery_address_domain" invisible="1"/>
                    <field name="delivery_address_id"
                        domain="[('id', 'in', delivery_address_domain)]"
                        options="{'no_create': True}"
                        required="1" widget="many2one_tags"/>
                </group>
                <footer>
                    <button name="action_grant_access" string="Grant Access"
                        type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
