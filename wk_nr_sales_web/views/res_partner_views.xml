<odoo>

    <!-- Add NR Sales ID to partner form -->
    <record id="nr_sales_partner_form_uid_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.nr.sales.uid</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="nr_sales_uid" readonly="1" invisible="not nr_sales_uid"/>
                <field name="nr_sales_state" invisible="not nr_sales_customer" readonly="1"
                    string="Customer Status"/>
            </xpath>
        </field>
    </record>

    <!-- NR Sales Customers search view (inherits base partner search) -->
    <record id="nr_sales_partner_search_view" model="ir.ui.view">
        <field name="name">nr.sales.partner.search</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="before">
                <field name="nr_sales_uid" string="NR Sales ID"/>
                <separator/>
                <filter name="nr_state_registration_request" string="Registration Request"
                    domain="[('nr_sales_state', '=', 'registration_request')]"/>
                <filter name="nr_state_request_accepted" string="Request Accepted"
                    domain="[('nr_sales_state', '=', 'request_accepted')]"/>
                <filter name="nr_state_portal_access_sent" string="Portal Access Sent"
                    domain="[('nr_sales_state', '=', 'portal_access_sent')]"/>
                <filter name="nr_state_active" string="Active"
                    domain="[('nr_sales_state', '=', 'active')]"/>
                <filter name="nr_state_revoked" string="Revoked"
                    domain="[('nr_sales_state', '=', 'revoked')]"/>
                <separator/>
            </xpath>
            <xpath expr="//group[@name='group_by']" position="inside">
                <filter name="group_by_nr_sales_state" string="Customer Status"
                    context="{'group_by': 'nr_sales_state'}"/>
            </xpath>
        </field>
    </record>

    <!-- NR Sales Customers list view -->
    <record id="nr_sales_partner_list_view" model="ir.ui.view">
        <field name="name">nr.sales.partner.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="NR Sales Customers"
                default_order="nr_sales_state"
                decoration-success="nr_sales_state == 'active'"
                decoration-info="nr_sales_state == 'portal_access_sent'"
                decoration-warning="nr_sales_state == 'request_accepted'"
                decoration-danger="nr_sales_state == 'revoked'"
                decoration-muted="nr_sales_state == 'registration_request'">
                <field name="name"/>
                <field name="nr_sales_uid" string="NR Sales ID"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="nr_sales_state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- NR Sales Customers form view -->
    <record id="nr_sales_partner_form_view" model="ir.ui.view">
        <field name="name">nr.sales.partner.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="NR Sales Customer">
                <header>
                    <button name="action_grant_nr_portal_access" string="Grant Portal Access"
                        type="object" class="btn-primary"
                        invisible="nr_sales_state in ('portal_access_sent', 'active')"/>
                    <button name="action_revoke_nr_portal_access" string="Revoke Access"
                        type="object"
                        invisible="nr_sales_state not in ('portal_access_sent', 'active')"/>
                    <field name="nr_sales_state" widget="statusbar"
                        statusbar_visible="registration_request,request_accepted,portal_access_sent,active"
                        readonly="0"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(nr_delivery_request_action)d"
                            type="action"
                            class="oe_stat_button"
                            icon="fa-truck"
                            context="{'default_partner_id': id, 'search_default_partner_id': id}">
                            <field name="delivery_request_count" widget="statinfo" string="Delivery Requests"/>
                        </button>
                        <button name="action_open_portal_users"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-user"
                            invisible="portal_user_count == 0">
                            <field name="portal_user_count" widget="statinfo" string="Users"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Customer Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Contact Information">
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group string="NR Sales">
                            <field name="nr_sales_customer" readonly="1"/>
                            <field name="nr_sales_uid" readonly="1" invisible="not nr_sales_uid"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State"
                                    options="{'no_open': True, 'no_quick_create': True}"
                                    context="{'default_country_id': country_id}"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" class="o_address_country"
                                    options='{"no_open": True, "no_create": True}'/>
                            </div>
                        </group>
                        <group/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="nr_sales_partner_action" model="ir.actions.act_window">
        <field name="name">Registration</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('nr_sales_customer', '=', True)]</field>
        <field name="context">{'default_nr_sales_customer': True}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('nr_sales_partner_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('nr_sales_partner_form_view')}),
        ]"/>
    </record>

    <!-- Child menu -->
    <menuitem id="nr_sales_customers_menu"
        name="Registration"
        parent="nr_sales_root_menu"
        action="nr_sales_partner_action"
        sequence="10"/>

</odoo>
