<odoo>

    <record id="nr_document_check_wizard_form_view" model="ir.ui.view">
        <field name="name">nr.document.check.wizard.form</field>
        <field name="model">nr.document.check.wizard</field>
        <field name="arch" type="xml">
            <form string="Document Check">
                <field name="has_supplier_invoice" invisible="1"/>
                <field name="has_shipping_documents" invisible="1"/>
                <field name="can_create_picking" invisible="1"/>
                <group>
                    <field name="request_id" readonly="1"/>
                </group>
                <div class="o_group">
                    <h6 class="o_horizontal_separator fw-bold">Document Status</h6>
                    <table class="table table-sm table-bordered mb-3" style="width:100%">
                            <thead>
                                <tr>
                                    <th style="width:40%">Document Type</th>
                                    <th style="width:20%">Status</th>
                                    <th style="width:40%">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Supplier Invoice</td>
                                    <td>
                                        <span class="badge rounded-pill bg-success"
                                            invisible="not has_supplier_invoice">Present</span>
                                        <span class="badge rounded-pill bg-warning text-dark"
                                            invisible="has_supplier_invoice">Missing</span>
                                    </td>
                                    <td>
                                        <button name="action_send_wa_supplier_invoice"
                                            string="Send WhatsApp Request"
                                            type="object"
                                            class="btn btn-sm btn-secondary"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Shipping Documents</td>
                                    <td>
                                        <span class="badge rounded-pill bg-success"
                                            invisible="not has_shipping_documents">Present</span>
                                        <span class="badge rounded-pill bg-warning text-dark"
                                            invisible="has_shipping_documents">Missing</span>
                                    </td>
                                    <td>
                                        <button name="action_send_wa_shipping_documents"
                                            string="Send WhatsApp Request"
                                            type="object"
                                            class="btn btn-sm btn-secondary"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                </div>
                <footer>
                    <button name="action_create_picking"
                        string="Create Picking"
                        type="object"
                        class="btn-primary"
                        invisible="not can_create_picking"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
