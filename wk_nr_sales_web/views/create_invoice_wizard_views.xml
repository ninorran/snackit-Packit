<odoo>

    <record id="nr_create_invoice_wizard_form_view" model="ir.ui.view">
        <field name="name">nr.create.invoice.wizard.form</field>
        <field name="model">nr.create.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Invoice">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="invoice_type" widget="radio"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <group invisible="invoice_type != 'other'">
                    <field name="amount" widget="monetary"/>
                    <field name="other_description"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm"
                        type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
