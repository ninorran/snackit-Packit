<odoo>

    <!-- Invoice form: add Product Description column to invoice lines list -->
    <record id="view_move_form_add_product_description" model="ir.ui.view">
        <field name="name">account.move.form.product_description</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='name']" position="after">
                <field name="product_description" string="Product Description" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Invoice form: rename "Product" column header to "Tracking #" -->
    <record id="view_move_form_rename_product_col" model="ir.ui.view">
        <field name="name">account.move.form.rename.product.col</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list[@name='journal_items']/field[@name='product_id']"
                   position="attributes">
                <attribute name="string">Tracking #</attribute>
            </xpath>
        </field>
    </record>

    <!-- Standalone move line form: add Product Description after name -->
    <record id="view_move_line_form_add_product_description" model="ir.ui.view">
        <field name="name">account.move.line.form.product_description</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="product_description" string="Product Description"/>
            </xpath>
        </field>
    </record>

</odoo>
