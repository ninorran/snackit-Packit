<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="nr_tariff_config_rule_company" model="ir.rule">
        <field name="name">NR Tariff Config: Multi-company</field>
        <field name="model_id" ref="model_nr_tariff_config"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="nr_sales_config_rule_company" model="ir.rule">
        <field name="name">NR Sales Config: Multi-company</field>
        <field name="model_id" ref="model_nr_sales_config"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="nr_delivery_request_rule_company" model="ir.rule">
        <field name="name">NR Delivery Request: Multi-company</field>
        <field name="model_id" ref="model_nr_delivery_request"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="nr_delivery_request_rule_portal" model="ir.rule">
        <field name="name">NR Delivery Request: Portal users see own records</field>
        <field name="model_id" ref="model_nr_delivery_request"/>
        <field name="domain_force">[('partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="nr_delivery_request_line_rule_portal" model="ir.rule">
        <field name="name">NR Delivery Request Line: Portal users see own lines</field>
        <field name="model_id" ref="model_nr_delivery_request_line"/>
        <field name="domain_force">[('request_id.partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
