<odoo noupdate="1">

    <record id="seq_nr_sales_uid" model="ir.sequence">
        <field name="name">NR Sales Customer ID</field>
        <field name="code">nr.sales.customer.uid</field>
        <field name="prefix">NRSUID</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_nr_delivery_request" model="ir.sequence">
        <field name="name">NR Delivery Request</field>
        <field name="code">nr.delivery.request</field>
        <field name="prefix">DR</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
