<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Redirect form: SKNPay returns a plain HTTPS checkout URL with no query params,
         so a simple GET form redirect is sufficient. -->
    <template id="redirect_form">
        <form t-att-action="api_url" method="get" id="o_payment_redirect_form"/>
    </template>

</odoo>
